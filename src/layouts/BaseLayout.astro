---
import '@fontsource/sorts-mill-goudy/400.css';
import '@fontsource/sorts-mill-goudy/400-italic.css';
import '@fontsource-variable/montserrat';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  canonical: string;
  robots?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogType?: string;
  jsonLd?: unknown | null;
  bodyClass?: string;
}
const {
  title,
  description = '',
  canonical,
  robots = 'index, follow',
  ogTitle,
  ogDescription,
  ogImage,
  ogType = 'website',
  jsonLd = null,
  bodyClass = '',
} = Astro.props;
const SITE_TAGLINE =
  'Authentic Ayurveda treatments, massage therapies and Panchakarma detox in Bondi Junction, Sydney.';
// Some migrated frontmatter strings carry literal HTML entities from the WP
// export; decode them at render so meta attributes hold the real characters
// (matching what Yoast emitted on the live site).
const decode = (s: string) =>
  s
    .replace(/&nbsp;/g, ' ')
    .replace(/&#(\d+);/g, (_, n) => String.fromCodePoint(Number(n)))
    .replace(/&hellip;/g, '…').replace(/&ndash;/g, '–').replace(/&mdash;/g, '—')
    .replace(/&quot;/g, '"').replace(/&#x27;|&apos;/g, "'")
    .replace(/&amp;/g, '&')
    .replace(/\s+/g, ' ')
    .trim();
const metaDescription = decode(description || ogDescription || SITE_TAGLINE);
const metaOgTitle = decode(ogTitle ?? title);
const metaOgDescription = decode(ogDescription || metaDescription);
const ogImageAbs = new URL(ogImage || '/wp-content/uploads/2023/01/featured_image.jpg', Astro.site).href;
---
<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content={robots} />

    <meta property="og:site_name" content="Ayurvedic Wellness Centre" />
    <meta property="og:locale" content="en_AU" />
    <meta property="og:title" content={metaOgTitle} />
    <meta property="og:description" content={metaOgDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@AyurvedicSydney" />
    <meta name="twitter:creator" content="@AyurvedicSydney" />
    <meta name="twitter:title" content={metaOgTitle} />
    <meta name="twitter:description" content={metaOgDescription} />
    <meta name="twitter:image" content={ogImageAbs} />
    <meta name="theme-color" content="#780032" />

    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body class={bodyClass}>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      // Scroll-reveal: progressively enhance [data-reveal] elements.
      const els = document.querySelectorAll('[data-reveal]');
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches && 'IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries, obs) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                obs.unobserve(e.target);
                // Watchdog: Chrome can leave a transition stuck at t=0 when the
                // renderer is throttled (occluded window, instant scroll jumps),
                // compositing the element at opacity 0 forever. Finish any
                // reveal transition that hasn't progressed past its duration.
                setTimeout(() => {
                  for (const a of e.target.getAnimations()) {
                    try { if (a.playState === 'running') a.finish(); } catch {}
                  }
                }, 900);
              }
            }
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.1 },
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add('is-visible'));
      }
    </script>

    <style>
      .skip-link {
        position: fixed; top: 0; left: 50%; translate: -50% -120%;
        z-index: 1000; background: var(--wine); color: var(--paper);
        padding: 0.7rem 1.2rem; border-radius: 0 0 var(--radius-m) var(--radius-m);
        font-size: 0.85rem; transition: translate var(--dur) var(--ease-out);
      }
      .skip-link:focus { translate: -50% 0; }
    </style>
  </body>
</html>
