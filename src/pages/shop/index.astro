---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { getJsonLd } from '../../lib/seo';
import { cardImage, routable, clean } from '../../lib/content';

// SEO comes verbatim from the migrated WP "shop" page; only the body is ours.
const entry = (await getCollection('pages')).find((e) => e.data.slug === 'shop')!;
const d = entry.data;
const products = (await getCollection('products', routable))
  .sort((a, b) => clean(a.data.title).localeCompare(clean(b.data.title)));
---
<BaseLayout
  title={d.title} description={d.description} canonical={d.canonical} robots={d.robots}
  ogTitle={d.ogTitle} ogDescription={d.ogDescription} ogImage={d.ogImage} ogType={d.ogType}
  jsonLd={getJsonLd('pages', d.slug)}
>
  <PageHero title="Shop" />
  <section class="section listing">
    <div class="container">
      <div class="listing__grid">
        {products.map((p, i) => (
          <ServiceCard href={p.data.path} title={clean(p.data.title)} image={cardImage(p)} excerpt={p.data.description} kicker="Gift Voucher" index={i} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .listing { padding-top: 3rem; }
  .listing__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 3.5rem 2rem; }
  @media (max-width: 940px) { .listing__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .listing__grid { grid-template-columns: 1fr; gap: 2.8rem; } }
</style>
