---
import { getCollection, render } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';
import { getJsonLd } from '../../lib/seo';

export async function getStaticPaths() {
  // every service migrated (noindex preserved via its robots tag)
  const entries = (await getCollection('services')).filter((e) => !e.data.draft);
  return entries.map((entry) => ({ params: { slug: entry.data.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const cleanTitle = (d.ogTitle || d.title).replace(/\s*[|]\s*Ayurvedic Wellness.*$/i, '').trim();
---
<ContentLayout
  title={d.title}
  cleanTitle={cleanTitle}
  description={d.description}
  canonical={d.canonical}
  robots={d.robots}
  ogTitle={d.ogTitle}
  ogDescription={d.ogDescription}
  ogImage={d.ogImage}
  ogType={d.ogType}
  jsonLd={getJsonLd('services', d.slug)}
  eyebrow="Ayurvedic Treatment"
  breadcrumbs={[{ label: 'Treatments', href: '/treatments/' }]}
  cta={{ label: 'Experience this treatment', href: '/book-appointment/', note: 'Book with our trained therapists in Bondi Junction.' }}
>
  <Content />
</ContentLayout>
