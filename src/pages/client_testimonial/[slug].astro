---
import { getCollection, render } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';
import { getJsonLd } from '../../lib/seo';
import { clean } from '../../lib/content';

export async function getStaticPaths() {
  const entries = (await getCollection('testimonials')).filter((e) => !e.data.draft);
  return entries.map((entry) => ({ params: { slug: entry.data.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const cleanTitle = clean(d.ogTitle || d.title);
---
<ContentLayout
  title={d.title}
  cleanTitle={cleanTitle}
  description={d.description}
  canonical={d.canonical}
  robots={d.robots}
  ogTitle={d.ogTitle}
  ogDescription={d.ogDescription}
  ogImage={d.ogImage}
  ogType={d.ogType}
  jsonLd={getJsonLd('testimonials', d.slug)}
  eyebrow="Words of Gratitude"
  breadcrumbs={[{ label: 'About', href: '/about-us/' }]}
>
  <Content />
</ContentLayout>
