---
import { getCollection, render } from 'astro:content';
import ContentLayout from '../layouts/ContentLayout.astro';
import { getJsonLd } from '../lib/seo';
import { formatDate, readingTime } from '../lib/content';

export async function getStaticPaths() {
  // Render EVERY post + page at its exact original URL (noindex preserved via robots).
  // Excluded only: pages replaced by designed routes — the homepage ('/'),
  // the 'shop' product index, and the 'ayurvedic-treatments' A–Z directory.
  const blog = await getCollection('blog');
  const pages = await getCollection('pages');
  const designed = new Set([
    'shop', 'ayurvedic-treatments', 'ayurvedic-spa', 'detox-clinic',
    'about-us', 'contact-us', 'book-appointment',
  ]);
  return [...blog, ...pages]
    .filter((e) => !e.data.draft && e.data.path !== '/' && !designed.has(e.data.slug))
    .map((entry) => ({
      // full path (handles nested URLs like /about/rita-sagrani/)
      params: { slug: entry.data.path.replace(/^\/|\/$/g, '') },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const isBlog = entry.collection === 'blog';
const cleanTitle = (d.ogTitle || d.title).replace(/\s*[|]\s*Ayurvedic Wellness.*$/i, '').trim();
const meta = isBlog ? [formatDate(d.pubDate), `${readingTime(entry.body)} min read`].filter(Boolean) : [];
const breadcrumbs = isBlog ? [{ label: 'Journal', href: '/journal/' }] : [];
---
<ContentLayout
  title={d.title}
  cleanTitle={cleanTitle}
  description={d.description}
  canonical={d.canonical}
  robots={d.robots}
  ogTitle={d.ogTitle}
  ogDescription={d.ogDescription}
  ogImage={d.ogImage}
  ogType={d.ogType}
  jsonLd={getJsonLd(entry.collection, d.slug)}
  eyebrow={isBlog ? 'From the Journal' : 'Ayurvedic Wellness Centre'}
  breadcrumbs={breadcrumbs}
  meta={meta}
  width="narrow"
>
  <Content />
</ContentLayout>
