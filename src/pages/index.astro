      <div class="insta" data-reveal>
        <span class="time">Follow Our Centre In Instagram</span>
        <a class="insta__handle" href="https://www.instagram.com/ayurvedicwellnesscentre/" rel="noopener" target="_blank">@ayurvedicwellnesscentre</a>
        <a class="btn btn--gold" href="https://www.instagram.com/ayurvedicwellnesscentre/" rel="noopener" target="_blank">Follow on Instagram</a>
      </div>
    </div>
  </section>

  <!-- =========================================== DEEP NIGHT · testimonies -->
  <section class="ch ch--deep" id="testimonials">
    <div class="wrap">
      <header class="ch__head" data-reveal>
        <p class="kicker">TestiMonials</p>
        <h2>What Our Clients <em>Say</em></h2>
        <img class="flourish" src={separator} alt="" width="398" height="36" loading="lazy" />
      </header>

      <div class="strip-head" data-reveal>
        <h3>Their Testimonies</h3>
        <span class="count">9 Videos</span>
      </div>
    </div>

    <div class="strip" data-reveal tabindex="0" role="region" aria-label="Client testimonial videos">
      {videos.map((v) => (
        <figure class="reel">
          <button class="yt" data-yt={v.id} aria-label={`Play video: ${v.title}`}>
            <img src={v.thumb} alt="" width="1280" height="720" loading="lazy" />
            <span class="yt__play" aria-hidden="true"></span>
            <span class="yt__dur">{v.dur}</span>
          </button>
          <figcaption>{v.title}</figcaption>
        </figure>
      ))}
    </div>

    <div class="wrap">
      <div class="strip-head written-head" data-reveal>
        <h3>Written Testimonials</h3>
      </div>
      <div class="quotes" data-reveal>
        {written.map((t) => (
          <figure class="quote">
            <blockquote><p>“{t.quote}”</p></blockquote>
            <figcaption>
              {t.href ? <a href={t.href}>{t.name}</a> : t.name}
              {t.label && <span>{t.label}</span>}
            </figcaption>
          </figure>
        ))}
