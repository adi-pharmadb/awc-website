>
  <!-- ============================================================ ticker -->
  <div class="ticker" aria-hidden="true">
    <div class="ticker__track">
      {[...ticker, ...ticker].map((t) => (
        <a href={t.href} tabindex="-1"><b>{t.name}</b><i>{t.note}</i><u>{t.tag}</u><span class="tsep">·</span></a>
      ))}
