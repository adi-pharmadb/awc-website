---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getJsonLd } from '../lib/seo';

// PHASE 2 — "Dinacharya": scrolling the homepage is living one day at the
// centre. The page travels dawn (paper) -> morning (gold) -> dusk (wine) ->
// lamplight (espresso) -> night (navy) through chained section gradients,
// with a fixed time-rail whose sun becomes a lamp as you descend.
// All migrated front-page content renders verbatim, placed at its hour.
const entry = (await getCollection('pages')).find((e) => e.data.slug === 'new-home-page')!;
const d = entry.data;

// Written testimonials: verbatim quotes from the migrated collection.
const testimonialEntries = await getCollection('testimonials');
const writtenOrder = [
  'Ashna Basu', 'Yan Ddd', 'Elvia Cacciotti', 'Heidi Gulla', 'Rachna Bhardwaj',
  'Manju Singh', 'Bhavna Dahiya', 'Gary McKinlay', 'Dr Veronica Ortiz',
  'Adrienn Gyenes', 'SC, Sydney', 'Achamma Kurlekar',
];
const written = writtenOrder.map((name) => {
  const e = testimonialEntries.find((t) => t.data.title.startsWith(`${name} |`));
  const body = e?.body ?? '';
  const label = body.match(/\*\*(.+?)\*\*/)?.[1]?.trim() ?? '';
  const quoted = [...body.matchAll(/“([^”]+)”/g)].map((m) => m[1].trim());
  const firstPara =
    body.split('\n').map((l) => l.trim()).filter((l) => l && !l.startsWith('**') && !l.startsWith('!['))[0] ?? '';
  let quote = quoted.sort((a, b) => b.length - a.length)[0] ?? '';
  if (quote.length < 25) quote = firstPara;
  if (quote.length > 230) {
    const cut = quote.slice(0, 230);
    const stop = cut.lastIndexOf('. ');
    quote = stop > 80 ? cut.slice(0, stop + 1) : `${cut.slice(0, cut.lastIndexOf(' '))}…`;
  }
  return { name, label, quote, href: e?.data.path ?? '' };
});

// Video testimonials — ids, titles and durations exactly as on the live page.
const videos = [
  { id: 'TqYTwx-Zt48', title: 'Ayurvedic Wellness Centre - Client Testimonial', dur: '1:37', thumb: '/wp-content/uploads/2023/12/maxresdefault.jpg' },
  { id: '5SfGs95BicY', title: 'Ayurvedic Wellness Centre - Client Testimonial', dur: '1:09', thumb: 'https://img.youtube.com/vi/5SfGs95BicY/maxresdefault.jpg' },
  { id: '3bDjSjIpJok', title: 'Ayurvedic Wellness Centre - Client Testimonial', dur: '1:06', thumb: 'https://img.youtube.com/vi/3bDjSjIpJok/maxresdefault.jpg' },
  { id: 'xQEs6BbSMjE', title: 'Ayurvedic Wellness Centre- Client Testimonial', dur: '1:01', thumb: 'https://img.youtube.com/vi/xQEs6BbSMjE/maxresdefault.jpg' },
  { id: 'uHmV0C3uIZ0', title: 'Transforming dreams into reality – Client Testimonial 🌟 #ayurvedalifestyle', dur: '0:44', thumb: 'https://img.youtube.com/vi/uHmV0C3uIZ0/maxresdefault.jpg' },
  { id: 'L-pDqMd9BjM', title: 'Ayurvedic Wellness Centre - Client Testimonial', dur: '0:33', thumb: 'https://img.youtube.com/vi/L-pDqMd9BjM/maxresdefault.jpg' },
  { id: 'P82hGf7kz_4', title: 'Ayurvedic Wellness Centre - Client Testimonial', dur: '0:32', thumb: 'https://img.youtube.com/vi/P82hGf7kz_4/maxresdefault.jpg' },
  { id: 'SpZeN08BUQw', title: 'Ayurvedic Wellness Centre - Client Testimonial', dur: '0:59', thumb: 'https://img.youtube.com/vi/SpZeN08BUQw/maxresdefault.jpg' },
  { id: 'x3BOD2p-tT4', title: 'Ayurvedic Wellness Centre - Client Testimonial #Abhyanga #Basti', dur: '0:37', thumb: 'https://img.youtube.com/vi/x3BOD2p-tT4/maxresdefault.jpg' },
];

const separator = '/wp-content/uploads/2023/05/asset_header_separator.svg';
---
<BaseLayout
  title={d.title}
  description={d.description}
  canonical="https://www.ayurvedicwellnesscentre.com.au/"
  ogType="website"
  ogImage={d.ogImage}
  jsonLd={getJsonLd('pages', d.slug)}
  bodyClass="home"
>
  <!-- ===================================================== the day rail -->
  <div class="rail" aria-hidden="true">
    <span class="rail__line"></span>
    <span class="rail__orb" data-orb></span>
  </div>
  <nav class="rail-labels" aria-label="Sections">
    <a href="#treatments" style="--at: 0%">Treatments</a>
    <a href="#ayurveda" style="--at: 20%">Ayurveda</a>
    <a href="#panchakarma" style="--at: 40%">Panchakarma</a>
    <a href="#story" style="--at: 60%">Story</a>
    <a href="#about" style="--at: 80%">About</a>
    <a href="#testimonials" style="--at: 100%">Testimonials</a>
  </nav>

  <!-- ===================================================== DAWN · hero -->
  <section class="ch ch--dawn">
    <div class="wrap">
      <p class="kicker" style="--rise: 0">A touch of ancient healing wisdom</p>
      <h1 style="--rise: 1">Authentic <em>Ayurveda</em> Experiences In&nbsp;Sydney</h1>
      <p class="hero-sub" style="--rise: 2">Treating stress &amp; anxiety, digestive issues, skin concerns and so much more.</p>
      <div class="cta-row" style="--rise: 3">
        <a class="btn" href="/book-appointment/">Find Out More</a>
        <a class="btn btn--ghost" href="tel:0293892581">Call Now</a>
      </div>
    </div>
    <div class="horizon wrap" aria-hidden="true"><span>scroll · the day begins</span></div>
  </section>

  <!-- ============================================ MORNING · dosha + practice -->
  <section class="ch ch--morning" id="treatments">
    <div class="wrap dosha" data-reveal>
      <div class="dosha__row">
        <div>
          <h2 class="dosha__title">Get A Free Quiz To Discover Your DOSHA!</h2>
          <p class="dosha__note">Sign up to our newsletter text, or something more in-depth to give more context to what’s behind the quiz.</p>
        </div>
        <a class="btn" href="/what-is-your-dosha">Download Now</a>
      </div>
    </div>

    <div class="wrap practice">
      <header class="ch__head" data-reveal>
        <p class="kicker">A touch of ancient healing wisdom</p>
        <h2>14 Years Offering Authentic Ayurvedic Treatments in <em>Bondi Junction, Sydney</em></h2>
        <img class="flourish" src={separator} alt="" width="398" height="36" loading="lazy" />
        <p class="lede">Ayurveda is something to experience and is not just a normal “massage”. The ancient Indian practice of rejuvenation comes from a place of reverence and the heart. For the first time, you can experience a complete range of authentic Ayurveda massage therapies, right here in Bondi Junction, Sydney. What’s more, you can choose to have a consultation with our qualified Doctors or our Ayurvedic Consultants.</p>
