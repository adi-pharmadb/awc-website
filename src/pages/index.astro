---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Ornament from '../components/Ornament.astro';
import { clean, pullQuote } from '../lib/content';
import { bookHref, phoneHref, instagram } from '../data/nav';

// --- Exact homepage images (from the live site) ---------------------------
const HERO_BG = '/wp-content/uploads/2023/05/background_banner.jpg';
const IMG_CONSULT = '/wp-content/uploads/elementor/thumbs/CONSULTATIONS-rkuf582g3hjy8t0aw0t32835mcwdr9zj3tjdaqt1tc.webp';
const IMG_ATOZ = '/wp-content/uploads/elementor/thumbs/Ayurveda-treats-A-Z-_Herbs_2-1-rkuf582g3hjy8t0aw0t32835mcwdr9zj3tjdaqt1tc.webp';
const IMG_SPA = '/wp-content/uploads/elementor/thumbs/SHIRODHARA-1-rkuf582g3hjy8t0aw0t32835mcwdr9zj3tjdaqt1tc.webp';
const IMG_WHATIS = '/wp-content/uploads/2023/05/What-Is-Ayurveda.jpg';
const IMG_CLIQUE = '/wp-content/uploads/elementor/thumbs/%C2%A9CliquePhotographySydney_G4H4474_Edit-rkuf574i9372gylbszubqtan2hqqdz66wrlvg4zp0w.jpg';
const IMG_MEDITATION = '/wp-content/uploads/elementor/thumbs/MEDITATION-ROOM-1-rkuf574i9372gylbszubqtan2hqqdz66wrlvg4zp0w.webp';
const IMG_FRAME = '/wp-content/uploads/elementor/thumbs/Frame-12-1-rkuf574i9372gylbszubqtan2hqqdz66wrlvg4zp0w.jpg';
const IMG_DEEPIKA = '/wp-content/uploads/elementor/thumbs/Dr-Deepika-rkuf574axyiqnb02ntd56rkidu9rizslzy26nk85xc.webp';
const IMG_TARUNA = '/wp-content/uploads/elementor/thumbs/Taruna-Yadav-newest-image-rkuf574axyiqnb02ntd56rkidu9rizslzy26nk85xc.webp';

// --- Testimonial videos (exact YouTube IDs from the live site) -------------
const VIDEO_IDS = ['5SfGs95BicY', '3bDjSjIpJok', 'xQEs6BbSMjE', 'uHmV0C3uIZ0', 'L-pDqMd9BjM', 'P82hGf7kz_4', 'SpZeN08BUQw', 'x3BOD2p-tT4', 'TqYTwx-Zt48'];

// Written testimonials (real content + quotes), preserving the homepage order
const ORDER = ['ashna-basu', 'yan-ddd', 'elvia-cacciotti', 'heidi-gulla', 'rachna-bhardwaj',
  'manju-singh', 'bhavna-dahiya', 'gary-mckinlay', 'dr-veronica-ortiz', 'adrienn-gyenes',
  'achamma-kurlekar-2', 'achamma-kurlekar'];
const tmap = new Map((await getCollection('testimonials')).map((t) => [t.data.slug, t]));
const written = ORDER.map((s) => tmap.get(s)).filter(Boolean).map((t) => ({
  quote: pullQuote(t!.body, 240), author: clean(t!.data.ogTitle ?? t!.data.title), href: t!.data.path,
}));

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'HealthAndBeautyBusiness',
  name: 'Ayurvedic Wellness Centre',
  url: 'https://www.ayurvedicwellnesscentre.com.au/',
  image: 'https://www.ayurvedicwellnesscentre.com.au/wp-content/uploads/2022/07/ayurvedic-new-main-logo.png',
  telephone: '+61293892581',
  email: 'info@ayurvedicwellnesscentre.com.au',
  address: { '@type': 'PostalAddress', addressLocality: 'Bondi Junction', addressRegion: 'NSW', addressCountry: 'AU' },
  foundingDate: '2011', priceRange: '$$',
  sameAs: ['https://www.facebook.com/AyurvedicWellnessCentre', 'https://www.instagram.com/ayurvedicwellnesscentre/', 'https://www.youtube.com/@AyurvedicWellness'],
};

const cards = [
  { img: IMG_CONSULT, alt: 'Ayurvedic Consultations', title: 'Ayurvedic Consultations',
    body: 'Meet our doctors- Dr.Deepika Kaushal and Dr.Taruna Yadav. Our experienced and qualified M.D. ayurvedic doctors have expertise in diagnosing and treating all health issues.',
    cta: 'More about Our Ayurvedic Doctors', href: '/team/' },
  { img: IMG_ATOZ, alt: 'Ayurveda massage therapies Sydney', title: 'Ayurveda Treatments A-Z',
    body: 'Ayurveda treats all disorders and goes to the root cause of the problem.',
    cta: 'Find Out More', href: '/ayurvedic-treatments/' },
  { img: IMG_SPA, alt: 'Ayurveda massage therapies Sydney', title: 'Day Spa Wellness',
    body: 'Indulge, Relax & Rejuvenate in luxury with authentic 5,000-year-old ancient ayurvedic spa treatments.',
    cta: 'View Our Packages', href: '/ayurvedic-spa/' },
];
---
<BaseLayout
  title="Ayurvedic Doctors in Sydney – Ayurvedic Medicine, Panchakarma and Ayurveda Massage Treatments"
  description="Experience authentic Ayurveda treatments and massage therapies, right here in Bondi Junction, Sydney with our best Ayurvedic Practitioners."
  canonical="https://www.ayurvedicwellnesscentre.com.au/"
  ogType="website"
  jsonLd={orgSchema}
  bodyClass="home"
>
  <!-- ============================ HERO ============================ -->
  <section class="hero">
    <div class="hero__media">
      <img src={HERO_BG} alt="" fetchpriority="high" />
      <div class="hero__scrim"></div>
    </div>
    <div class="container hero__inner">
      <p class="eyebrow hero__eyebrow">A touch of ancient healing wisdom</p>
      <h1 class="hero__title">Authentic Ayurveda Experiences In Sydney</h1>
      <p class="hero__lead">Treating stress &amp; anxiety, digestive issues, skin concerns and so much more.</p>
      <div class="hero__actions">
        <a class="btn btn--gold" href="/what-is-ayurveda/">Find Out More</a>
        <a class="btn btn--on-dark hero__ghost" href={phoneHref}>Call Now</a>
      </div>
    </div>
    <a class="hero__scroll" href="#intro" aria-label="Scroll to learn more"><span></span></a>
  </section>

  <!-- ====================== DOSHA QUIZ STRIP ===================== -->
  <section class="quiz-strip">
    <div class="container quiz-strip__inner">
      <Ornament variant="mark" size={24} class="quiz-strip__mark" />
      <div class="quiz-strip__text">
        <h2 class="quiz-strip__title">Get A Free Quiz To Discover Your DOSHA!</h2>
        <p>Sign up to our newsletter text, or something more in-depth to give more context to what’s behind the quiz.</p>
      </div>
      <a class="btn btn--gold" href="/what-is-your-dosha/">Download Now</a>
    </div>
  </section>

  <!-- =================== INTRO + THREE OFFERINGS ================== -->
  <section class="section intro" id="intro">
    <div class="container">
      <header class="intro__head" data-reveal>
        <p class="eyebrow eyebrow--center">A touch of ancient healing wisdom</p>
        <h2 class="intro__title">14 Years Offering Authentic Ayurvedic Treatments in Bondi Junction, Sydney</h2>
        <Ornament variant="divider" class="intro__ornament" />
        <p class="intro__copy">Ayurveda is something to experience and is not just a normal “massage”. The ancient Indian
          practice of rejuvenation comes from a place of reverence and the heart. For the first time, you can
          experience a complete range of authentic Ayurveda massage therapies, right here in Bondi Junction, Sydney.
          What’s more, you can choose to have a consultation with our qualified Doctors or our Ayurvedic Consultants.</p>
      </header>

      <div class="offer-grid">
        {cards.map((c, i) => (
          <a class="offer-card" href={c.href} data-reveal style={`--reveal-delay:${i * 100}ms`}>
            <div class="offer-card__media"><img src={c.img} alt={c.alt} loading="lazy" /></div>
            <div class="offer-card__body">
              <h3 class="offer-card__title">{c.title}</h3>
              <p class="offer-card__copy">{c.body}</p>
              <span class="offer-card__cta">{c.cta} <span aria-hidden="true">→</span></span>
            </div>
          </a>
        ))}
      </div>

      <div class="intro__actions" data-reveal>
        <a class="btn btn--wine" href={bookHref}>Book an Appointment</a>
        <a class="btn btn--ghost" href={phoneHref}>Phone Us Now</a>
      </div>
    </div>
  </section>

  <!-- ======================= WHAT IS AYURVEDA ==================== -->
  <section class="section whatis">
    <div class="container whatis__grid">
      <div class="whatis__figure" data-reveal>
        <img src={IMG_WHATIS} alt="What Is Ayurveda" loading="lazy" />
      </div>
      <div class="whatis__text" data-reveal style="--reveal-delay:120ms">
        <p class="eyebrow">An Ancient Practice for Modern Living</p>
        <h2 class="whatis__title">What Is Ayurveda</h2>
        <p class="whatis__copy">Ayurveda is the traditional healing system of India and is practised by around 70% of
          India’s population. Dating back over 5000 years, the roots of Ayurveda are deeply steeped in history and
          tradition. There are mentions of the healing system in the first of the Hindu texts and the “Chakra Samhita”,
          the still cited Ayurvedic text on internal medicine appeared around the turn of the first millennium BC. It is
          estimated that there are currently around 650,000 doctors practising this science in India today with 70,000
          doctors practising worldwide. Numbers which give a strong indication of the modern day popularity of the
          health system.</p>
        <a class="btn btn--wine" href="/what-is-ayurveda/">Find Out More</a>
      </div>
    </div>
  </section>

  <!-- ======================= PANCHAKARMA DETOX =================== -->
  <section class="detox">
    <div class="container">
      <header class="detox__head" data-reveal>
        <p class="eyebrow eyebrow--center">Ayurvedic Wellness Centre</p>
        <h2 class="detox__title">14 Years of Authentic Ayurvedic Healing: Panchakarma Detox Therapy in Sydney</h2>
        <Ornament variant="divider" class="detox__ornament" />
        <p class="detox__lead">Has your busy schedule left you feeling the need to cleanse and rejuvenate your body and
          mind? Ancient Ayurvedic Panchakarma Detox therapy helps eliminate toxins, improve digestion, boost energy
          levels and strengthen the immune system.</p>
      </header>

      <div class="detox__block" data-reveal>
        <div class="detox__text stack">
          <h3>What Is Panchakarma Detox?</h3>
          <p>Ayurveda believes that the buildup of toxins in the tissues and blockage of channels of circulation are
            the root cause of many chronic conditions.</p>
          <p>Panchakarma Detox is a therapeutic system that cleanses toxins that are already in your body and are the
            underlying cause of health imbalances and diseases.</p>
          <p>Ayurveda has used these cleansing treatments to rejuvenate the mind and body since ancient times. Book a
            treatment and discover the difference Panchakarma can make to your wellbeing.</p>
          <a class="link" href="/detox-clinic/">Find Out More →</a>
        </div>
        <div class="detox__figure"><img src={IMG_CLIQUE} alt="©CliquePhotographySydney_G4H4474_Edit" loading="lazy" /></div>
      </div>

      <div class="detox__block detox__block--reverse" data-reveal>
        <div class="detox__figure"><img src={IMG_MEDITATION} alt="Ayurveda Experiences in Bondi Junction, Sydney" loading="lazy" /></div>
        <div class="detox__text stack">
          <h3>Why Choose Panchakarma Detox?</h3>
          <p>For 14 years, Ayurvedic Wellness Centre has been helping Sydney clients transform their health with
            authentic Panchakarma Detox Therapy. This ancient Ayurvedic program combines therapeutic massages, herbal
            treatments, and gentle cleansing procedures that work synergistically to restore balance and promote
            overall wellbeing.</p>
          <p>This ancient Ayurvedic therapy helps to:</p>
          <ul class="detox__list" role="list">
            <li>Eliminate toxins</li>
            <li>Improve digestion</li>
            <li>Boost energy levels</li>
            <li>Enhance mental clarity</li>
            <li>Promote weight loss</li>
            <li>Boost healthy skin and complexion</li>
            <li>Strengthen the immune system</li>
          </ul>
          <p>You can look forward to improved health, vitality and a renewed sense of wellness after your treatment.</p>
          <a class="btn btn--wine" href={bookHref}>Book Your Appointment</a>
        </div>
      </div>

      <div class="detox__longer stack" data-reveal>
        <h3>Longer Treatments For Deeper, More Holistic Cleansing</h3>
        <p>Ayurveda says that when Panchakarma treatments are administered daily for several days in a row, cleansing
          begins to occur at a deeper level.</p>
        <p>According to Ayurveda, a 7-Day treatment is ideal as it is believed to sequentially cleanse and rejuvenate
          all 7 major bodily tissues.</p>
        <p>At the Ayurvedic Wellness Centre, these treatments are offered under the supervision of our highly qualified
          and experienced Ayurvedic practitioners.</p>
        <p>Contact us for a bespoke treatment plan, which could be a 5-day, 7-day, 9-day plan based on your current
          level of wellbeing.</p>
        <p>Reclaim a sense of balance… book your initial consultation today.</p>
        <a class="btn btn--wine" href={bookHref}>Book Your Appointment</a>
      </div>
    </div>
  </section>

  <!-- ======================= NOT SURE WHERE ====================== -->
  <section class="start-band">
    <div class="start-band__media"><img src={IMG_FRAME} alt="Frame 12 (1)" loading="lazy" /></div>
    <div class="container start-band__inner">
      <div class="start-band__text" data-reveal>
        <h2 class="start-band__title">Not Sure Where To Start?</h2>
        <p>We’ll be happy to have a quick chat and suggest you the best way for you to embark on your ayurvedic journey
          with us!</p>
        <div class="start-band__actions">
          <a class="btn btn--gold" href={bookHref}>Book an Appointment</a>
          <a class="btn btn--on-dark-ghost" href={phoneHref}>Phone Us Now</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ======================= REAL LIFE STORY ===================== -->
  <section class="section story">
    <div class="container--narrow text-center" data-reveal>
      <p class="eyebrow eyebrow--center">Manage Your Stress &amp; Anxiety</p>
      <h2 class="story__title">Real Life Story From Our Client</h2>
      <Ornament variant="divider" class="story__ornament" />
      <p class="story__copy">Vanessa completed her 7-day Ayurvedic detox to help with her stress, and anxiety and to stop
        smoking. As a busy individual in a fast-paced job, Vanessa found herself to be stressed a lot of the time which
        exacerbated her anxiety. Along with this, she had been smoking for several years which she wanted to stop to
        look after herself. Watch this video to listen to her experience of the 7-day detox at the Ayurvedic Wellness
        Centre.</p>
      <p class="story__sub">Looking For Ways To Live Stress-Free Life?</p>
      <p class="story__sub-copy">Don’t wait for it – we’re a call away to help you transform your life.</p>
      <a class="btn btn--wine" href={bookHref}>Book an Appointment</a>
    </div>
  </section>

  <!-- ============================ ABOUT ========================== -->
  <section class="section about">
    <div class="container">
      <header class="about__head" data-reveal>
        <p class="eyebrow eyebrow--center">Our Passion Is Your Wellbeing</p>
        <h2 class="about__title">About Us &amp; Our Wellness Centre</h2>
        <Ornament variant="divider" class="about__ornament" />
      </header>
      <div class="about__copy" data-reveal>
        <p>The Ayurvedic Wellness Centre was opened in 2011 by Rita Sagrani. It is the first true oasis in Sydney that
          offers the authentic experience of true Ayurveda. With fully qualified doctors and therapists, the Ayurvedic
          Wellness Centre is devoted to the client, ensuring correct diagnosis, prescription of genuine, high-quality
          Ayurvedic herbs and oils and the professional application of healing, holistic therapies. The Ayurvedic
          Wellness Centre has become the preferred establishment in natural and holistic healing.</p>
        <p>With the warmth, compassion and expertise of our highly trained staff, we offer a truly authentic experience,
          restoring internal equilibrium, balance and well-being for the mind, body and soul. The Ayurvedic Wellness
          Centre seeks to educate the wider community about the principles of Ayurveda, as well as progressing with our
          long term goal of opening Ayurvedic Clinics and Hospitals throughout Australia to bring the power of Ayurvedic
          healing to everyone.</p>
      </div>

      <div class="doctors">
        <a class="doctor" href="/doctor/dr-deepika-kaushal/" data-reveal>
          <div class="doctor__media"><img src={IMG_DEEPIKA} alt="Dr Deepika Kaushal Ayurvedic Doctor Bondi Junction" loading="lazy" /></div>
          <div class="doctor__body">
            <h3 class="doctor__name">Dr. Deepika Kaushal B.A.M.S. M.D</h3>
            <p>Our Ayurvedic Doctor, Dr. Deepika is a motivated and young medicine professional with extensive
              experience in herbal medicine and acupuncture therapy. Dr. Deepika’s expertise is to diagnose chronic and
              complicated illnesses, and follow tailored and holistic treatment plans.</p>
          </div>
        </a>
        <a class="doctor" href="/doctor/dr-taruna-yadav/" data-reveal style="--reveal-delay:110ms">
          <div class="doctor__media"><img src={IMG_TARUNA} alt="Taruna-Yadav-newest-image" loading="lazy" /></div>
          <div class="doctor__body">
            <h3 class="doctor__name">Dr Taruna Yadav B.A.M.S.</h3>
            <p>Our Ayurvedic Doctor, Taruna (Bachelor of Ayurvedic Medicine &amp; Surgery, Maharishi Dayanand
              University, India) is registered with AAA (Australasian Association of Ayurveda).</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ========================= INSTAGRAM ========================= -->
  <section class="insta">
    <div class="container text-center" data-reveal>
      <p class="eyebrow eyebrow--center">Follow Our Centre In Instagram</p>
      <a class="insta__handle" href={instagram} target="_blank" rel="noopener">@ayurvedicwellnesscentre</a>
      <div><a class="btn btn--wine" href={instagram} target="_blank" rel="noopener">Follow on Instagram</a></div>
    </div>
  </section>

  <!-- ======================= TESTIMONIALS ======================== -->
  <section class="section testimonials">
    <div class="container">
      <header class="testimonials__head" data-reveal>
        <p class="eyebrow eyebrow--center">Testimonials</p>
        <h2 class="testimonials__title">What Our Clients Say</h2>
        <Ornament variant="divider" class="testimonials__ornament" />
      </header>

      <h3 class="testimonials__sub" data-reveal>Their Testimonies</h3>
      <div class="video-grid">
        {VIDEO_IDS.map((id, i) => (
          <a class="video" href={`https://www.youtube.com/watch?v=${id}`} target="_blank" rel="noopener"
             data-reveal style={`--reveal-delay:${(i % 3) * 80}ms`} aria-label="Watch client testimonial on YouTube">
            <img src={`https://i.ytimg.com/vi/${id}/hqdefault.jpg`} alt="Ayurvedic Wellness Centre - Client Testimonial" loading="lazy" />
            <span class="video__play" aria-hidden="true"></span>
          </a>
        ))}
      </div>

      <h3 class="testimonials__sub testimonials__sub--written" data-reveal>Written Testimonials</h3>
      <div class="written-grid">
        {written.map((t, i) => (
          <figure class="written" data-reveal style={`--reveal-delay:${(i % 3) * 80}ms`}>
            <Ornament variant="mark" size={20} class="written__mark" />
            <blockquote>{t.quote}</blockquote>
            <figcaption><a href={t.href}>{t.author}</a></figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---------------- HERO ---------------- */
  .hero { position: relative; min-height: clamp(540px, 86vh, 820px); display: grid; align-items: center; isolation: isolate; }
  .hero__media { position: absolute; inset: 0; z-index: -1; overflow: hidden; }
  .hero__media img { width: 100%; height: 100%; object-fit: cover; object-position: 70% center; animation: kenburns 22s var(--ease-in-out) infinite alternate; }
  @keyframes kenburns { from { transform: scale(1.04); } to { transform: scale(1.14); } }
  @media (prefers-reduced-motion: reduce) { .hero__media img { animation: none; } }
  .hero__scrim { position: absolute; inset: 0; background:
    linear-gradient(100deg, color-mix(in srgb, var(--espresso) 88%, transparent) 0%, color-mix(in srgb, var(--espresso) 55%, transparent) 42%, transparent 78%),
    linear-gradient(to top, color-mix(in srgb, var(--espresso) 70%, transparent), transparent 42%); }
  .hero__inner { position: relative; padding-block: clamp(3rem, 8vh, 6rem); max-width: 56rem; }
  .hero__eyebrow { color: var(--gold); }
  .hero__title { color: var(--paper); font-size: clamp(2.6rem, 1.4rem + 5vw, 5rem); line-height: 1.05; margin-top: 1.2rem; letter-spacing: -0.01em; text-transform: capitalize; }
  .hero__lead { color: var(--on-dark-soft); font-size: var(--step-1); max-width: 40ch; margin-top: 1.5rem; line-height: 1.55; }
  .hero__actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 2.1rem; }
  .hero__ghost { background: transparent; box-shadow: inset 0 0 0 1px rgba(246,237,224,0.5); color: var(--on-dark); }
  .hero__ghost:hover { background: var(--on-dark); color: var(--espresso); }
  .hero__scroll { position: absolute; bottom: 1.6rem; left: 50%; translate: -50% 0; width: 26px; height: 42px; border: 1px solid rgba(246,237,224,0.5); border-radius: 14px; display: grid; justify-items: center; padding-top: 7px; }
  .hero__scroll span { width: 3px; height: 8px; background: var(--gold); border-radius: 2px; animation: scrolldot 1.8s var(--ease-in-out) infinite; }
  @keyframes scrolldot { 0% { opacity: 0; transform: translateY(-4px); } 40% { opacity: 1; } 100% { opacity: 0; transform: translateY(10px); } }

  .btn--wine { --btn-bg: var(--wine); --btn-fg: var(--paper); }

  /* ---------------- QUIZ STRIP ---------------- */
  .quiz-strip { background: var(--espresso); color: var(--on-dark); }
  .quiz-strip__inner { display: flex; align-items: center; gap: 1.5rem 2.5rem; padding-block: 2rem; flex-wrap: wrap; }
  .quiz-strip__mark { color: var(--gold); flex-shrink: 0; }
  .quiz-strip__text { flex: 1 1 22rem; }
  .quiz-strip__title { color: var(--on-dark); font-size: var(--step-2); }
  .quiz-strip__text p { color: var(--on-dark-soft); font-size: 0.92rem; margin-top: 0.4rem; }

  /* ---------------- INTRO + OFFERINGS ---------------- */
  .intro__head { max-width: 60rem; margin-inline: auto; text-align: center; }
  .intro__title { font-size: var(--step-3); margin-top: 1rem; }
  .intro__ornament { margin: 1.5rem auto; max-width: 16rem; }
  .intro__copy { color: var(--ink-soft); font-size: var(--step-0); line-height: 1.75; }
  .offer-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 3rem; }
  .offer-card { display: flex; flex-direction: column; background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius-l); overflow: hidden; transition: transform var(--dur) var(--ease-out), box-shadow var(--dur) var(--ease-out); }
  .offer-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-l); }
  .offer-card__media { aspect-ratio: 3 / 2; overflow: hidden; background: var(--paper-3); }
  .offer-card__media img { width: 100%; height: 100%; object-fit: cover; transition: transform var(--dur-slow) var(--ease-out); }
  .offer-card:hover .offer-card__media img { transform: scale(1.06); }
  .offer-card__body { padding: 1.6rem; display: flex; flex-direction: column; gap: 0.6rem; flex: 1; }
  .offer-card__title { font-size: var(--step-2); color: var(--wine); }
  .offer-card__copy { font-size: 0.92rem; color: var(--ink-soft); line-height: 1.6; flex: 1; }
  .offer-card__cta { font-size: 0.74rem; font-weight: 600; text-transform: uppercase; letter-spacing: var(--tracking-caps); color: var(--gold-deep); display: inline-flex; gap: 0.5em; }
  .offer-card__cta span { transition: transform var(--dur) var(--ease-out); }
  .offer-card:hover .offer-card__cta span { transform: translateX(4px); }
  .intro__actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-top: 3rem; }
  @media (max-width: 880px) { .offer-grid { grid-template-columns: 1fr; max-width: 28rem; margin-inline: auto; } }

  /* ---------------- WHAT IS AYURVEDA ---------------- */
  .whatis__grid { display: grid; grid-template-columns: 0.85fr 1fr; gap: clamp(2rem, 6vw, 5rem); align-items: center; }
  .whatis__figure img { width: 100%; border-radius: var(--radius-l); box-shadow: var(--shadow-l); aspect-ratio: 4 / 5; object-fit: cover; }
  .whatis__title { font-size: var(--step-4); margin-top: 0.8rem; }
