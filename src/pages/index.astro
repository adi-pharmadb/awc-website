---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceCard from '../components/ServiceCard.astro';
import PostCard from '../components/PostCard.astro';
import Ornament from '../components/Ornament.astro';
import { cardImage, routable } from '../lib/content';
import { bookHref } from '../data/nav';

const services = await getCollection('services', routable);
const featuredSlugs = [
  'shirodhara-treatment-bondi-sydney',
  'ayurvedic-massage-in-bondi-junction',
  'panchakarma-ayurvedic-detox-sydney',
  'pizzichil-treatment',
  'udvartana-massage-for-weight-loss-sydney',
  'couples-massage',
];
const featured = featuredSlugs
  .map((s) => services.find((x) => x.data.slug === s))
  .filter(Boolean) as typeof services;

const posts = (await getCollection('blog', routable))
  .sort((a, b) => (b.data.pubDate ?? '').localeCompare(a.data.pubDate ?? ''))
  .slice(0, 3);

const doctors = await getCollection('doctors', routable);

const testimonials = (await getCollection('testimonials'))
  .filter((t) => (t.data.ogDescription ?? '').length > 120 && !/ddd|test/i.test(t.data.slug))
  .slice(0, 3);

const doshas = [
  { name: 'Vata', element: 'Air & Ether', qualities: 'Movement · Creativity · Lightness', tint: 'navy',
    note: 'Governs breath, circulation and the nervous system. When balanced: vitality and clarity.' },
  { name: 'Pitta', element: 'Fire & Water', qualities: 'Transformation · Focus · Heat', tint: 'wine',
    note: 'Governs digestion, metabolism and intellect. When balanced: warmth and contentment.' },
  { name: 'Kapha', element: 'Earth & Water', qualities: 'Structure · Calm · Endurance', tint: 'gold',
    note: 'Governs immunity, strength and stability. When balanced: steadiness and compassion.' },
];

const heroImg = '/wp-content/uploads/2023/05/background_banner.jpg';
const philosophyImg = '/wp-content/uploads/2023/05/What-Is-Ayurveda.jpg';
const detoxImg = '/wp-content/uploads/2023/05/background_about_us-1-scaled.jpg';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'HealthAndBeautyBusiness',
  name: 'Ayurvedic Wellness Centre',
  url: 'https://www.ayurvedicwellnesscentre.com.au/',
  image: 'https://www.ayurvedicwellnesscentre.com.au/wp-content/uploads/2022/07/ayurvedic-new-main-logo.png',
  telephone: '+61293892581',
  email: 'info@ayurvedicwellnesscentre.com.au',
  address: { '@type': 'PostalAddress', addressLocality: 'Bondi Junction', addressRegion: 'NSW', addressCountry: 'AU' },
  foundingDate: '2011',
  priceRange: '$$',
  sameAs: [
    'https://www.facebook.com/AyurvedicWellnessCentre',
    'https://www.instagram.com/ayurvedicwellnesscentre/',
    'https://www.youtube.com/@AyurvedicWellness',
  ],
};
---
<BaseLayout
  title="Ayurvedic Wellness Centre — Authentic Ayurveda in Bondi Junction, Sydney"
  description="Experience authentic Ayurveda treatments, massage therapies and Panchakarma detox in Bondi Junction, Sydney, with our qualified Ayurvedic doctors."
  canonical="https://www.ayurvedicwellnesscentre.com.au/"
  ogType="website"
  jsonLd={orgSchema}
  bodyClass="home"
>
  <!-- ============================ HERO ============================ -->
  <section class="hero">
    <div class="hero__media">
      <img src={heroImg} alt="Ayurvedic herbal treatment at the Ayurvedic Wellness Centre" fetchpriority="high" />
      <div class="hero__scrim"></div>
    </div>
    <div class="container hero__inner">
      <p class="eyebrow hero__eyebrow">A Touch of Ancient Healing Wisdom</p>
      <h1 class="hero__title">Authentic Ayurveda<br />Experiences in Sydney</h1>
      <p class="hero__lead">
        Five thousand years of healing wisdom, practised with reverence in the heart of Bondi
        Junction — for stress &amp; anxiety, digestion, skin, sleep and so much more.
      </p>
      <div class="hero__actions">
        <a class="btn btn--gold" href={bookHref}>Book an Appointment</a>
        <a class="btn btn--on-dark hero__ghost" href="/treatments/">Explore Treatments</a>
      </div>
    </div>
    <div class="hero__est">
      <span>Est.</span><span>2011</span>
    </div>
    <a class="hero__scroll" href="#philosophy" aria-label="Scroll to learn more">
      <span></span>
    </a>
  </section>

  <!-- ======================= PHILOSOPHY ========================== -->
  <section class="section philosophy" id="philosophy">
    <div class="container philosophy__grid">
      <div class="philosophy__figure" data-reveal>
        <img src={philosophyImg} alt="An Ayurvedic practitioner preparing herbal oils" loading="lazy" />
        <div class="philosophy__badge">
          <Ornament variant="mark" size={20} />
          <span>5000<small>years of wisdom</small></span>
        </div>
      </div>
      <div class="philosophy__text">
        <SectionHeader
          eyebrow="An Ancient Practice for Modern Living"
          title="What Is Ayurveda"
        />
        <div class="philosophy__body stack" data-reveal style="--reveal-delay:120ms">
          <p>
            Ayurveda is the traditional healing system of India — a science of life practised by
            millions for over five millennia. Where modern medicine often treats the symptom,
            Ayurveda seeks the root: restoring balance between mind, body and spirit.
          </p>
          <p>
            At its heart are the three <em>doshas</em> — Vata, Pitta and Kapha — the energies that
            shape your constitution. Understanding yours is the beginning of lasting wellbeing.
          </p>
          <a class="link" href="/what-is-ayurveda/">Read the full philosophy</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========================= DOSHAS ============================ -->
  <section class="section doshas">
    <div class="container">
      <SectionHeader
        align="center"
        eyebrow="Know Your Nature"
        title="The Three Doshas"
        intro="Every person is a unique expression of three vital energies. Balance is health; imbalance is dis-ease."
      />
      <div class="doshas__grid">
        {doshas.map((d, i) => (
          <article class:list={['dosha-card', `tint-${d.tint}`]} data-reveal style={`--reveal-delay:${i * 110}ms`}>
            <div class="dosha-card__symbol"><Ornament variant="mark" size={30} /></div>
            <h3 class="dosha-card__name">{d.name}</h3>
            <p class="dosha-card__element">{d.element}</p>
            <p class="dosha-card__qual">{d.qualities}</p>
            <p class="dosha-card__note">{d.note}</p>
          </article>
        ))}
      </div>
      <div class="doshas__cta" data-reveal>
        <a class="btn btn--ghost" href="/what-is-your-dosha/">Discover Your Dosha</a>
      </div>
    </div>
  </section>

  <!-- ====================== SIGNATURE TREATMENTS ================= -->
  <section class="section treatments-feature">
    <div class="container">
      <div class="treatments-feature__head">
        <SectionHeader
          eyebrow="Ayurveda A–Z"
          title="Signature Treatments"
          intro="Authentic therapies performed by trained therapists with warm, medicated oils and time-honoured technique."
        />
        <a class="link treatments-feature__all" href="/treatments/">All treatments →</a>
      </div>
      <div class="treatments-feature__grid">
        {featured.map((s, i) => (
          <ServiceCard
            href={s.data.path}
            title={s.data.title.replace(/\s*[|–-].*$/, '')}
            image={cardImage(s)}
            excerpt={s.data.description}
            kicker="Therapy"
            index={i}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ======================= PANCHAKARMA BAND ==================== -->
  <section class="detox-band">
    <div class="detox-band__media"><img src={detoxImg} alt="Panchakarma detox treatment room" loading="lazy" /></div>
    <div class="container detox-band__inner">
      <div class="detox-band__text" data-reveal>
        <p class="eyebrow">The Detox Clinic</p>
        <h2 class="detox-band__title">Panchakarma — A Deeper, More Holistic Cleanse</h2>
        <p class="detox-band__copy">
          When treatments are administered daily over several days, cleansing begins at a far
          deeper level. Our individualised 7-day Panchakarma programmes sequentially purify and
          rejuvenate all seven tissues of the body — under the care of our Ayurvedic doctors.
        </p>
        <ul class="detox-band__list" role="list">
          <li>Personalised to your constitution &amp; concerns</li>
          <li>Doctor consultation, massage, steam &amp; herbal supplements</li>
          <li>Renewed energy, vitality and clarity</li>
        </ul>
        <a class="btn btn--gold" href="/detox-clinic/">Explore Panchakarma</a>
      </div>
    </div>
  </section>

  <!-- ======================= PRACTITIONERS ======================= -->
  {doctors.length > 0 && (
    <section class="section practitioners">
      <div class="container">
        <SectionHeader align="center" eyebrow="In Trusted Hands" title="Meet Our Doctors" />
        <div class="practitioners__grid">
          {doctors.map((doc, i) => (
            <a class="practitioner" href={doc.data.path} data-reveal style={`--reveal-delay:${i * 110}ms`}>
              <div class="practitioner__media">
                {cardImage(doc) ? <img src={cardImage(doc)} alt={doc.data.title} loading="lazy" /> : <div class="practitioner__ph"></div>}
              </div>
              <div class="practitioner__body">
                <h3 class="practitioner__name">{doc.data.title.replace(/\s*[|–-].*$/, '')}</h3>
                <p class="practitioner__role">Ayurvedic Doctor</p>
                <span class="practitioner__cta">View profile →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ======================= TESTIMONIALS ======================== -->
  {testimonials.length > 0 && (
    <section class="section testimonials">
      <div class="container">
        <SectionHeader align="center" eyebrow="Words of Gratitude" title="Stories of Healing" />
        <div class="testimonials__grid">
          {testimonials.map((t, i) => (
            <figure class="quote" data-reveal style={`--reveal-delay:${i * 110}ms`}>
              <Ornament variant="mark" size={22} class="quote__mark" />
              <blockquote>{(t.data.ogDescription ?? '').replace(/\s*\[&hellip;\].*$/, '…').slice(0, 240)}</blockquote>
              <figcaption>{(t.data.ogTitle ?? t.data.title).replace(/\s*[|].*$/, '')}</figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ========================= JOURNAL =========================== -->
  {posts.length > 0 && (
    <section class="section journal-preview">
      <div class="container">
        <div class="journal-preview__head">
          <SectionHeader eyebrow="From the Journal" title="Ayurvedic Wisdom" />
          <a class="link" href="/journal/">All articles →</a>
        </div>
        <div class="journal-preview__grid">
          {posts.map((p, i) => (
            <PostCard
              href={p.data.path}
              title={p.data.title.replace(/\s*[|–].*$/, '')}
              image={cardImage(p)}
              excerpt={p.data.description}
              date={p.data.pubDate}
              body={p.body}
              index={i}
            />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  /* ---------------- HERO ---------------- */
  .hero { position: relative; min-height: clamp(560px, 88vh, 880px); display: grid; align-items: center; isolation: isolate; }
  .hero__media { position: absolute; inset: 0; z-index: -1; overflow: hidden; }
  .hero__media img { width: 100%; height: 100%; object-fit: cover; object-position: 70% center; animation: kenburns 22s var(--ease-in-out) infinite alternate; }
  @keyframes kenburns { from { transform: scale(1.04); } to { transform: scale(1.14); } }
  @media (prefers-reduced-motion: reduce) { .hero__media img { animation: none; } }
  .hero__scrim { position: absolute; inset: 0; background:
    linear-gradient(100deg, color-mix(in srgb, var(--espresso) 88%, transparent) 0%, color-mix(in srgb, var(--espresso) 55%, transparent) 42%, transparent 78%),
    linear-gradient(to top, color-mix(in srgb, var(--espresso) 70%, transparent), transparent 40%); }

  .hero__inner { position: relative; padding-block: clamp(3rem, 8vh, 7rem); max-width: 60rem; }
  .hero__eyebrow { color: var(--gold); }
  .hero__title { color: var(--paper); font-size: clamp(2.7rem, 1.4rem + 5.4vw, 5.4rem); line-height: 1.04; margin-top: 1.2rem; letter-spacing: -0.01em; }
  .hero__lead { color: var(--on-dark-soft); font-size: var(--step-1); max-width: 46ch; margin-top: 1.6rem; line-height: 1.6; }
  .hero__actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 2.2rem; }
  .hero__ghost { background: transparent; box-shadow: inset 0 0 0 1px rgba(246,237,224,0.5); color: var(--on-dark); }
  .hero__ghost:hover { background: var(--on-dark); color: var(--espresso); }

  .hero__est {
    position: absolute; right: var(--gutter); top: 50%; translate: 0 -50%;
    writing-mode: vertical-rl; display: grid; gap: 0.4rem; text-align: center;
    font-family: var(--font-display); color: var(--gold); font-size: 0.9rem; letter-spacing: 0.3em;
    opacity: 0.85;
  }
  .hero__est::before { content: ''; display: block; height: 3rem; width: 1px; background: var(--gold); margin: 0 auto 0.6rem; opacity: 0.6; }
  @media (max-width: 900px) { .hero__est { display: none; } }

  .hero__scroll { position: absolute; bottom: 1.6rem; left: 50%; translate: -50% 0; width: 26px; height: 42px; border: 1px solid rgba(246,237,224,0.5); border-radius: 14px; display: grid; justify-items: center; padding-top: 7px; }
  .hero__scroll span { width: 3px; height: 8px; background: var(--gold); border-radius: 2px; animation: scrolldot 1.8s var(--ease-in-out) infinite; }
  @keyframes scrolldot { 0% { opacity: 0; transform: translateY(-4px); } 40% { opacity: 1; } 100% { opacity: 0; transform: translateY(10px); } }

  /* ---------------- PHILOSOPHY ---------------- */
  .philosophy__grid { display: grid; grid-template-columns: 0.95fr 1fr; gap: clamp(2rem, 6vw, 5rem); align-items: center; }
  .philosophy__figure { position: relative; }
  .philosophy__figure img { width: 100%; border-radius: var(--radius-l); box-shadow: var(--shadow-l); aspect-ratio: 4 / 5; object-fit: cover; }
  .philosophy__badge {
    position: absolute; bottom: -1.5rem; right: -1.5rem;
    background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius-l);
    box-shadow: var(--shadow-m); padding: 1.1rem 1.4rem; display: flex; align-items: center; gap: 0.8rem;
    color: var(--gold-deep);
  }
  .philosophy__badge span { display: grid; font-family: var(--font-display); font-size: 2rem; color: var(--wine); line-height: 1; }
  .philosophy__badge small { font-family: var(--font-sans); font-size: 0.62rem; text-transform: uppercase; letter-spacing: var(--tracking-caps); color: var(--taupe); margin-top: 0.3rem; }
  @media (max-width: 820px) { .philosophy__grid { grid-template-columns: 1fr; } .philosophy__figure { max-width: 26rem; } .philosophy__badge { right: 1rem; } }

  /* ---------------- DOSHAS ---------------- */
  .doshas { background: var(--paper-2); }
  .doshas__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 3.5rem; }
  .dosha-card {
    --accent: var(--taupe);
    background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius-l);
    padding: 2.2rem 1.8rem; text-align: center; position: relative; overflow: hidden;
    transition: transform var(--dur) var(--ease-out), box-shadow var(--dur) var(--ease-out);
  }
  .dosha-card::before { content: ''; position: absolute; inset: 0 0 auto 0; height: 4px; background: var(--accent); }
  .dosha-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-l); }
  .tint-navy { --accent: var(--navy); }
  .tint-wine { --accent: var(--wine); }
  .tint-gold { --accent: var(--gold-deep); }
  .dosha-card__symbol { color: var(--accent); display: flex; justify-content: center; margin-bottom: 0.8rem; }
  .dosha-card__name { font-size: var(--step-3); color: var(--accent); }
  .dosha-card__element { font-size: 0.72rem; text-transform: uppercase; letter-spacing: var(--tracking-eyebrow); color: var(--taupe); margin-top: 0.4rem; }
  .dosha-card__qual { font-family: var(--font-display); font-style: italic; font-size: 1.05rem; color: var(--ink); margin-top: 1rem; }
  .dosha-card__note { font-size: 0.86rem; color: var(--ink-soft); margin-top: 0.8rem; line-height: 1.6; }
  .doshas__cta { text-align: center; margin-top: 3rem; }

  /* ---------------- TREATMENTS ---------------- */
  .treatments-feature__head { display: flex; align-items: flex-end; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
  .treatments-feature__all { white-space: nowrap; }
  .treatments-feature__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 3rem; }
  @media (max-width: 940px) { .treatments-feature__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .treatments-feature__grid, .doshas__grid { grid-template-columns: 1fr; } }

  /* ---------------- DETOX BAND ---------------- */
  .detox-band { position: relative; isolation: isolate; color: var(--on-dark); padding-block: var(--space-3xl); margin-top: var(--space-2xl); }
  .detox-band__media { position: absolute; inset: 0; z-index: -1; overflow: hidden; }
  .detox-band__media img { width: 100%; height: 100%; object-fit: cover; }
  .detox-band::after { content: ''; position: absolute; inset: 0; z-index: -1; background:
    linear-gradient(90deg, color-mix(in srgb, var(--navy-deep) 92%, transparent), color-mix(in srgb, var(--navy-deep) 70%, transparent) 55%, transparent); }
  .detox-band__text { max-width: 38rem; }
  .detox-band .eyebrow { color: var(--gold); }
  .detox-band__title { color: var(--on-dark); font-size: var(--step-4); margin-top: 0.8rem; }
  .detox-band__copy { color: var(--on-dark-soft); margin-top: 1.2rem; line-height: 1.7; }
  .detox-band__list { margin-top: 1.4rem; display: grid; gap: 0.7rem; }
  .detox-band__list li { position: relative; padding-left: 1.8rem; color: var(--on-dark-soft); font-size: 0.92rem; }
  .detox-band__list li::before { content: ''; position: absolute; left: 0; top: 0.55em; width: 0.5em; height: 0.5em; border-radius: 50%; background: var(--gold); }
  .detox-band .btn { margin-top: 2rem; }

  /* ---------------- PRACTITIONERS ---------------- */
  .practitioners__grid { display: grid; grid-template-columns: repeat(2, minmax(0, 22rem)); gap: 2rem; justify-content: center; margin-top: 3.5rem; }
  .practitioner { display: grid; gap: 1.2rem; text-align: center; }
  .practitioner__media { aspect-ratio: 3 / 4; border-radius: var(--radius-l); overflow: hidden; box-shadow: var(--shadow-m); background: var(--paper-3); }
  .practitioner__media img { width: 100%; height: 100%; object-fit: cover; transition: transform var(--dur-slow) var(--ease-out); }
  .practitioner:hover .practitioner__media img { transform: scale(1.05); }
  .practitioner__ph { width: 100%; height: 100%; background: radial-gradient(circle at 30% 30%, var(--paper-2), var(--paper-3)); }
  .practitioner__name { font-size: var(--step-2); color: var(--wine); }
  .practitioner__role { font-size: 0.74rem; text-transform: uppercase; letter-spacing: var(--tracking-eyebrow); color: var(--taupe); margin-top: 0.3rem; }
  .practitioner__cta { display: inline-block; margin-top: 0.7rem; font-size: 0.78rem; color: var(--gold-deep); font-weight: 600; }
  @media (max-width: 600px) { .practitioners__grid { grid-template-columns: 1fr; } }

  /* ---------------- TESTIMONIALS ---------------- */
  .testimonials { background: var(--paper-2); }
  .testimonials__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 3.5rem; }
  .quote { background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius-l); padding: 2rem; display: grid; gap: 1rem; }
  .quote__mark { color: var(--gold-deep); }
  .quote blockquote { font-family: var(--font-display); font-size: 1.12rem; line-height: 1.5; color: var(--ink); font-style: italic; }
  .quote figcaption { font-size: 0.74rem; text-transform: uppercase; letter-spacing: var(--tracking-eyebrow); color: var(--taupe); font-weight: 600; }
  @media (max-width: 860px) { .testimonials__grid { grid-template-columns: 1fr; } }

  /* ---------------- JOURNAL ---------------- */
  .journal-preview__head { display: flex; align-items: flex-end; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
  .journal-preview__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2.2rem; margin-top: 3rem; }
  @media (max-width: 860px) { .journal-preview__grid { grid-template-columns: 1fr; gap: 2.5rem; } }
</style>
