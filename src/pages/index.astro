        <span class="meta right">Twelve written · nine on film · on record</span>
        <span class="meta no">06 · Testimonies</span>
        <p class="kicker">TestiMonials</p>
        <h2>What Our Clients <em>Say</em></h2>
        <img class="flourish" src={separator} alt="" width="398" height="36" loading="lazy" />
      </header>

      <div class="strip-head" data-reveal>
        <h3>Their Testimonies</h3>
        <span class="meta count">9 Videos</span>
      </div>
    </div>

    <div class="strip" data-reveal tabindex="0" role="region" aria-label="Client testimonial videos">
      {videos.map((v) => (
        <figure class="reel">
          <button class="yt" data-yt={v.id} aria-label={`Play video: ${v.title}`}>
            <img src={v.thumb} alt="" width="1280" height="720" loading="lazy" />
            <span class="yt__play" aria-hidden="true"></span>
            <span class="yt__dur">{v.dur}</span>
          </button>
          <figcaption>{v.title}</figcaption>
        </figure>
      ))}
    </div>

    <div class="rwrap">
      <div class="strip-head written-head" data-reveal>
        <h3>Written Testimonials</h3>
        <span class="meta count">12 on record</span>
      </div>
      <div class="quotes" data-reveal>
        {written.map((t) => (
          <figure class="quote">
            <blockquote><p>“{t.quote}”</p></blockquote>
            <figcaption>
              {t.href ? <a href={t.href}>{t.name}</a> : t.name}
              {t.label && <span>{t.label}</span>}
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // YouTube facades: swap the poster for a real (autoplaying) embed on demand.
  document.querySelectorAll<HTMLButtonElement>('[data-yt]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.yt!;
      const frame = document.createElement('iframe');
      frame.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
      frame.title = btn.getAttribute('aria-label') ?? 'Video';
      frame.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
      frame.allowFullscreen = true;
      frame.className = 'yt-frame';
      btn.replaceWith(frame);
      frame.focus();
    });
  });
</script>

