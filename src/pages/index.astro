          </div>
          <div class="disc"><img src="/wp-content/uploads/elementor/thumbs/CONSULTATIONS-rkuf582g3hjy8t0aw0t32835mcwdr9zj3tjdaqt1tc.webp" alt="CONSULTATIONS" width="900" height="600" loading="lazy" /></div>
        </article>
        <article class="seq__item" data-reveal>
          <span class="seq__no">ii.</span>
          <div class="seq__body">
