</BaseLayout>

<script>
  // YouTube facades: swap the poster for a real (autoplaying) embed on demand.
  document.querySelectorAll<HTMLButtonElement>('[data-yt]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.yt!;
      const frame = document.createElement('iframe');
      frame.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
      frame.title = btn.getAttribute('aria-label') ?? 'Video';
      frame.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
      frame.allowFullscreen = true;
      frame.className = 'yt-frame';
      btn.replaceWith(frame);
      frame.focus();
    });
  });

  // The day rail: the sun travels down as you scroll and becomes a lamp at
  // night; the active section's label lights up. Transform/paint only.
  const orb = document.querySelector<HTMLElement>('[data-orb]');
  const labels = [...document.querySelectorAll<HTMLAnchorElement>('.rail-labels a')];
  const sections = labels.map((l) => document.querySelector<HTMLElement>(l.hash));
  if (orb && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let ticking = false;
    const paint = () => {
      ticking = false;
      const max = document.documentElement.scrollHeight - innerHeight;
      const p = Math.min(1, Math.max(0, scrollY / Math.max(1, max)));
      orb.style.top = `${p * 100}%`;
      orb.style.setProperty('--lamp', String(0.45 + p * 0.55));
      let active = -1;
      sections.forEach((s, i) => { if (s && s.getBoundingClientRect().top < innerHeight * 0.55) active = i; });
      labels.forEach((l, i) => l.classList.toggle('on', i === active));
      document.body.classList.toggle('day-dark', p > 0.52);
    };
    addEventListener('scroll', () => { if (!ticking) { ticking = true; requestAnimationFrame(paint); } }, { passive: true });
    paint();
  }
</script>

<style>
  /* ======================== Dinacharya — the day, in chained gradients ===
     dawn paper -> morning gold -> afternoon paper -> dusk wine ->
     lamplight espresso -> evening/night navy -> deep night.
     Each chapter's gradient begins where the previous one ended, so the
     scroll reads as one continuous sky. */
  .wrap { max-width: 76rem; margin-inline: auto; padding-inline: var(--gutter); }
  .ch { position: relative; }

  .time {
    display: inline-flex; align-items: center; gap: 0.8em;
    font-family: var(--font-sans); font-size: 0.64rem; font-weight: 700;
    letter-spacing: 0.26em; text-transform: uppercase;
    color: var(--taupe);
  }
  .time::after { content: ''; width: 3.2em; height: 1px; background: currentColor; opacity: 0.5; }

