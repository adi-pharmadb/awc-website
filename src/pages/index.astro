---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getJsonLd } from '../lib/seo';

// PHASE 1 — faithful content port. The homepage renders the REAL front-page
// content (every word + image, verbatim) in a clean, neutral layout.
// Design comes in a later pass.
const entry = (await getCollection('pages')).find((e) => e.data.slug === 'new-home-page')!;
const { Content } = await render(entry);
const d = entry.data;
---
<BaseLayout
  title={d.title}
  description={d.description}
  canonical="https://www.ayurvedicwellnesscentre.com.au/"
  ogType="website"
  ogImage={d.ogImage}
  jsonLd={getJsonLd('pages', d.slug)}
  bodyClass="home"
>
  <div class="page">
    <div class="container">
      <div class="prose">
        <Content />
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .page { padding-block: clamp(2rem, 5vw, 4rem); }
  .prose { margin-inline: auto; }
</style>
