---
import Ornament from './Ornament.astro';
interface Props {
  href: string;
  title: string;
  image?: string;
  excerpt?: string;
  kicker?: string;
  index?: number;
}
const { href, title, image, excerpt, kicker, index = 0 } = Astro.props;
const num = String(index + 1).padStart(2, '0');
---
<a class="service-card" href={href} data-reveal style={`--reveal-delay:${(index % 3) * 90}ms`}>
  <div class="service-card__disc">
    {image ? (
      <img src={image} alt={title} loading="lazy" decoding="async" />
    ) : (
      <div class="service-card__placeholder"><Ornament variant="mark" size={36} /></div>
    )}
  </div>
  <div class="service-card__body">
    <span class="service-card__num">{num}</span>
    {kicker && <span class="service-card__kicker">{kicker}</span>}
    <h3 class="service-card__title">{title}</h3>
    {excerpt && <p class="service-card__excerpt">{excerpt}</p>}
    <span class="service-card__cta">Explore ›</span>
  </div>
</a>

<style>
  /* a "time disc" entry, not a boxed card */
  .service-card { display: grid; justify-items: center; text-align: center; align-content: start; }

  .service-card__disc {
    width: clamp(150px, 14vw, 190px); height: clamp(150px, 14vw, 190px);
    border-radius: 50%; overflow: hidden; background: var(--paper-3);
    box-shadow:
      0 0 0 1px rgba(51, 23, 3, 0.35),
      0 0 0 7px rgba(253, 197, 120, 0.22),
      0 18px 40px -18px rgba(51, 23, 3, 0.45);
  }
  .service-card__disc img { width: 100%; height: 100%; object-fit: cover; transition: transform var(--dur-slow) var(--ease-out); }
  .service-card:hover .service-card__disc img { transform: scale(1.07); }
  .service-card__placeholder {
    width: 100%; height: 100%;
    display: grid; place-items: center;
    color: var(--gold-deep);
    background: radial-gradient(circle at 32% 30%, var(--paper-2), var(--paper-3));
  }

  .service-card__body { display: grid; justify-items: center; gap: 0.35rem; padding-top: 1.2rem; max-width: 30ch; }
  .service-card__num { font-family: var(--font-display); font-style: italic; font-size: 1.05rem; color: var(--gold-deep); line-height: 1; }
  .service-card__kicker { font-size: 0.62rem; text-transform: uppercase; letter-spacing: var(--tracking-eyebrow); color: var(--mushroom); font-weight: 600; }
  .service-card__title { font-size: var(--step-1); color: var(--wine); text-transform: capitalize; line-height: 1.18; transition: color var(--dur); }
  .service-card:hover .service-card__title { color: var(--gold-deep); }
  .service-card__excerpt { font-size: 0.85rem; color: var(--ink-soft); line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .service-card__cta {
    margin-top: 0.5rem;
    font-family: var(--font-display); font-style: italic; font-size: 1rem; color: var(--gold-deep);
    border-bottom: 1px solid rgba(201, 138, 46, 0.55); padding-bottom: 1px;
    transition: border-color var(--dur);
  }
  .service-card:hover .service-card__cta { border-color: var(--gold-deep); }
</style>
