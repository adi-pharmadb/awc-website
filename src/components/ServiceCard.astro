---
interface Props {
  href: string;
  title: string;
  image?: string;
  excerpt?: string;
  kicker?: string;
  index?: number;
}
const { href, title, image, excerpt, kicker, index = 0 } = Astro.props;
const num = String(index + 1).padStart(2, '0');
---
<a class="service-card" href={href} data-reveal style={`--reveal-delay:${(index % 3) * 90}ms`}>
  <div class="service-card__media">
    {image ? (
      <img src={image} alt={title} loading="lazy" decoding="async" />
    ) : (
      <div class="service-card__placeholder"></div>
    )}
    <span class="service-card__num">{num}</span>
  </div>
  <div class="service-card__body">
    {kicker && <span class="service-card__kicker">{kicker}</span>}
    <h3 class="service-card__title">{title}</h3>
    {excerpt && <p class="service-card__excerpt">{excerpt}</p>}
    <span class="service-card__cta">Explore <span aria-hidden="true">→</span></span>
  </div>
</a>

<style>
  .service-card {
    display: flex; flex-direction: column;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius-l);
    overflow: hidden;
    transition: transform var(--dur) var(--ease-out), box-shadow var(--dur) var(--ease-out), border-color var(--dur);
  }
  .service-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-l); border-color: transparent; }

  .service-card__media { position: relative; aspect-ratio: 4 / 3; overflow: hidden; background: var(--paper-3); }
  .service-card__media img { width: 100%; height: 100%; object-fit: cover; transition: transform var(--dur-slow) var(--ease-out); }
  .service-card:hover .service-card__media img { transform: scale(1.06); }
  .service-card__placeholder { width: 100%; height: 100%; background:
    radial-gradient(circle at 30% 30%, var(--paper-2), var(--paper-3)); }
  .service-card__num {
    position: absolute; top: 0.9rem; left: 0.9rem;
    font-family: var(--font-display); font-size: 0.85rem; color: var(--paper);
    background: color-mix(in srgb, var(--espresso) 55%, transparent);
    backdrop-filter: blur(4px);
    width: 2.2rem; height: 2.2rem; display: grid; place-items: center; border-radius: 50%;
    letter-spacing: 0.02em;
  }

  .service-card__body { padding: 1.5rem 1.5rem 1.7rem; display: flex; flex-direction: column; gap: 0.55rem; flex: 1; }
  .service-card__kicker { font-size: 0.68rem; text-transform: uppercase; letter-spacing: var(--tracking-eyebrow); color: var(--taupe); font-weight: 600; }
  .service-card__title { font-size: var(--step-1); color: var(--wine); text-transform: capitalize; line-height: 1.15; }
  .service-card__excerpt { font-size: 0.88rem; color: var(--ink-soft); line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .service-card__cta { margin-top: auto; padding-top: 0.6rem; font-size: 0.74rem; font-weight: 600; text-transform: uppercase; letter-spacing: var(--tracking-caps); color: var(--gold-deep); display: inline-flex; gap: 0.5em; }
  .service-card__cta span { transition: transform var(--dur) var(--ease-out); }
  .service-card:hover .service-card__cta span { transform: translateX(4px); }
</style>
