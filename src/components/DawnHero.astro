---
import Ornament from './Ornament.astro';
interface Props { title: string; kicker?: string; crumb?: boolean }
const { title, kicker, crumb = true } = Astro.props;
---
<header class="dawn-hero">
  <div class="container--narrow text-center">
    {crumb && <nav class="dawn-hero__crumbs" aria-label="Breadcrumb"><a href="/">Home</a></nav>}
    {kicker && <p class="kicker dawn-hero__kicker">{kicker}</p>}
    <h1>{title}</h1>
    <Ornament variant="divider" class="dawn-hero__ornament" />
  </div>
</header>

<style>
  .dawn-hero {
    padding-top: clamp(3.5rem, 7vw, 6rem);
    padding-bottom: clamp(1.5rem, 3vw, 2.5rem);
    background:
      radial-gradient(70vw 34vh at 50% 100%, rgba(253, 197, 120, 0.28), transparent 70%),
      linear-gradient(to bottom, var(--paper), #f9f1e2);
  }
  .dawn-hero__crumbs { font-size: 0.7rem; text-transform: uppercase; letter-spacing: var(--tracking-caps); color: var(--mushroom); margin-bottom: 1.4rem; }
  .dawn-hero__crumbs a:hover { color: var(--wine); }
  .dawn-hero__kicker { margin-bottom: 0.8rem; }
  .dawn-hero h1 { font-size: var(--step-5); letter-spacing: -0.01em; }
  .dawn-hero__ornament { margin: 2rem auto 0; max-width: 16rem; }
</style>
