---
import { formatDate, readingTime } from '../lib/content';
interface Props {
  href: string;
  title: string;
  image?: string;
  excerpt?: string;
  date?: string;
  body?: string;
  index?: number;
  featured?: boolean;
}
const { href, title, image, excerpt, date, body, index = 0, featured = false } = Astro.props;
---
<article class:list={['post-card', { 'is-featured': featured }]} data-reveal style={`--reveal-delay:${(index % 3) * 90}ms`}>
  <a class="post-card__link" href={href}>
    <div class="post-card__media">
      {image ? <img src={image} alt={title} loading="lazy" decoding="async" /> : <div class="post-card__ph"></div>}
    </div>
    <div class="post-card__body">
      <div class="post-card__meta">
        {date && <time>{formatDate(date)}</time>}
        {body && <><span aria-hidden="true">·</span><span>{readingTime(body)} min read</span></>}
      </div>
      <h3 class="post-card__title">{title}</h3>
      {excerpt && <p class="post-card__excerpt">{excerpt}</p>}
      <span class="post-card__cta">Read article <span aria-hidden="true">→</span></span>
    </div>
  </a>
</article>

<style>
  .post-card__link { display: grid; gap: 1.2rem; }
  .post-card__media { aspect-ratio: 3 / 2; overflow: hidden; border: 1px solid var(--line); border-radius: 3px; background: var(--paper-3); }
  .post-card__media img { width: 100%; height: 100%; object-fit: cover; transition: transform var(--dur-slow) var(--ease-out); }
  .post-card:hover .post-card__media img { transform: scale(1.05); }
  .post-card__ph { width: 100%; height: 100%; background: radial-gradient(circle at 30% 30%, var(--paper-2), var(--paper-3)); }

  .post-card__meta { display: flex; gap: 0.6rem; font-size: 0.72rem; text-transform: uppercase; letter-spacing: var(--tracking-caps); color: var(--taupe); }
  .post-card__title {
    margin-top: 0.7rem; font-size: var(--step-2); color: var(--wine); line-height: 1.18; text-transform: none;
    transition: color var(--dur);
  }
  .post-card:hover .post-card__title { color: var(--gold-deep); }
  .post-card__excerpt { margin-top: 0.6rem; font-size: 0.9rem; color: var(--ink-soft); line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .post-card__cta {
    display: inline-flex; gap: 0.4em; margin-top: 0.9rem; justify-self: start;
    font-family: var(--font-display); font-style: italic; font-size: 1rem; color: var(--gold-deep);
    border-bottom: 1px solid rgba(201, 138, 46, 0.55); padding-bottom: 1px;
  }
  .post-card__cta span { transition: transform var(--dur) var(--ease-out); }
  .post-card:hover .post-card__cta span { transform: translateX(4px); }

  /* featured: side-by-side, larger */
  .is-featured .post-card__link { grid-template-columns: 1.15fr 1fr; align-items: center; gap: 2.5rem; }
  .is-featured .post-card__media { aspect-ratio: 4 / 3; }
  .is-featured .post-card__title { font-size: var(--step-3); }
  @media (max-width: 760px) { .is-featured .post-card__link { grid-template-columns: 1fr; gap: 1.2rem; } }
</style>
