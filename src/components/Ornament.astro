---
// A calligraphic flame/leaf ornament echoing the logo's linework.
// Variants: 'divider' (rules + flame) | 'mark' (flame only).
interface Props { variant?: 'divider' | 'mark'; class?: string; size?: number }
const { variant = 'divider', class: cls = '', size = 26 } = Astro.props;
---
{variant === 'divider' ? (
  <div class:list={['ornament', cls]} aria-hidden="true">
    <svg width={size} height={size * 1.5} viewBox="0 0 24 34" fill="none">
      <path d="M12 33 C 3 25, 6 13, 12 1 C 18 13, 21 25, 12 33 Z" stroke="currentColor" stroke-width="1.1" stroke-linejoin="round"/>
      <path d="M12 27 C 9 22, 10 14, 12 9 C 14 14, 15 22, 12 27" stroke="currentColor" stroke-width="0.9" opacity="0.7"/>
    </svg>
  </div>
) : (
  <svg class={cls} width={size} height={size * 1.5} viewBox="0 0 24 34" fill="none" aria-hidden="true">
    <path d="M12 33 C 3 25, 6 13, 12 1 C 18 13, 21 25, 12 33 Z" stroke="currentColor" stroke-width="1.1" stroke-linejoin="round"/>
    <path d="M12 27 C 9 22, 10 14, 12 9 C 14 14, 15 22, 12 27" stroke="currentColor" stroke-width="0.9" opacity="0.7"/>
  </svg>
)}
